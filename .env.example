# Restic Repository
# Beispiel: rclone:google-drive:backups/nas
RESTIC_REPOSITORY="rclone:remote:path/to/repo"
RESTIC_PASSWORD="your_secure_password_here"

# Rclone Konfiguration
RCLONE_CONFIG="/root/.config/rclone/rclone.conf"

# Multi-Target Backup Konfiguration
# Format: "PFAD:TAG PFAD2:TAG2"
# Leerzeichen getrennt.
# Beispiel: "/mnt/data:omv /mnt/usr/apps/paperless-ngx/export:paperless"
BACKUP_TARGETS="/path/to/source1:tag1 /path/to/source2:tag2"

# Deprecated: Single Source Backup
# BACKUP_SOURCE="/mnt/data"

# Retention Policy
RETENTION_LAST=10
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=6
RETENTION_YEARLY=1
